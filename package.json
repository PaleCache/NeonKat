{
  "name": "neonkat",
  "version": "0.4.1",
  "description": "A simple yet not music player with visualizer and miniplayer",
  "author": "PaleCache",
  "homepage": "https://github.com/palecache/neonkat",
  "main": "main.js",
  "desktopName": "com.palecache.NeonKat.desktop",
  "scripts": {
    "start": "GTK_USE_PORTAL=0 GDK_BACKEND=wayland electron .",
    "build": "electron-builder",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.palecache.NeonKat",
    "productName": "NeonKat",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "styles.css",
      "renderer/**/*",
      "build/**/*",
      "jsmediatags.min.js",
      "hls.js@latest",
      "build/NeonKat.desktop",
      "build/com.palecache.NeonKat.metainfo.xml"
    ],
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "palecache",
        "repo": "neonkat"
      }
    ],
    "asarUnpack": [
      "node_modules/ffprobe-static/**"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "icon": "build/kat.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/kat.png",
      "category": "Audio",
      "maintainer": "PaleCache",
      "syncDesktopName": true,
      "artifactName": "${productName}-${version}-x86_64.${ext}"
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0"
      ]
    }
  },
  "devDependencies": {
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.7.3",
    "ffprobe-static": "^3.1.0"
  }
}
